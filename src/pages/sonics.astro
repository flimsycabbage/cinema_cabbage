---
import Layout from '../layouts/Layout.astro';
---

<Layout title="sonics">
	<a href="/" class="entrance-link">entrance</a>
	<main>
		<div class="content">
			<div class="columns-container">
				<!-- Cinema Column -->
				<div class="column">
					<h2 class="artist-name">aud/vid</h2>
					<div class="widget-container">
						<iframe 
							id="youtube-widget"
							width="100%" 
							height="166" 
							frameborder="no" 
							allow="autoplay; encrypted-media" 
							allowfullscreen
							src="">
						</iframe>
					</div>
				</div>

				<!-- Thomas Grasha Column -->
				<div class="column">
					<h2 class="artist-name">thomas grasha</h2>
					<div class="widget-container">
						<iframe 
							id="tg-widget"
							width="100%" 
							height="166" 
							scrolling="no" 
							frameborder="no" 
							allow="autoplay" 
							src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/thomasgrasha&color=%23ff5500&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false">
						</iframe>
					</div>
				</div>

				<!-- LPDO Column -->
				<div class="column">
					<a href="https://soundcloud.com/lpdo" target="_blank" rel="noopener noreferrer" class="sonics-link">
						lpdo
					</a>
					<div class="widget-container">
						<iframe 
							id="lpdo-widget"
							width="100%" 
							height="166" 
							scrolling="no" 
							frameborder="no" 
							allow="autoplay" 
							src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/lpdo&color=%23ff5500&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false">
						</iframe>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>

<script is:inline src="https://w.soundcloud.com/player/api.js"></script>
<script is:inline>
	const videoIds = [
		'AGfbRxwhERQ', 'e8RflzZCz8k', 'aLpNGYvz2wc', 'R2x8PZXeWUU', 
		'QeLMcI-kOjo', '1UnqkdKo8CY', 'CEpKOt8MBUk', 'E2tcz_ZZWSg', 
		'aQfKqntoh_E', 'TjpkZpGnqJs', 'W4N-HeBTrfQ', 'U5uiaw7PVxo', 
		'3Kdp1q0VfOA', '3aon2f5iSiI'
	];

	function setupRandomWidget(id) {
		const iframe = document.querySelector('#' + id);
		if (!iframe) return;
		
		const widget = SC.Widget(iframe);
		widget.bind(SC.Widget.Events.READY, () => {
			widget.getSounds((sounds) => {
				if (sounds && sounds.length > 0) {
					const randomIndex = Math.floor(Math.random() * sounds.length);
					widget.skip(randomIndex);
					widget.bind(SC.Widget.Events.PLAY, function onPlay() {
						widget.pause();
						widget.unbind(SC.Widget.Events.PLAY, onPlay);
					});
				}
			});
		});
	}

	function setupRandomYouTube(id) {
		const iframe = document.querySelector('#' + id);
		if (!iframe) return;
		const randomIndex = Math.floor(Math.random() * videoIds.length);
		const selectedId = videoIds[randomIndex];
		iframe.src = `https://www.youtube.com/embed/${selectedId}?autoplay=0&rel=0`;
	}

	setupRandomWidget('lpdo-widget');
	setupRandomWidget('tg-widget');
	setupRandomYouTube('youtube-widget');
</script>

<style is:global>
	body, html {
		overflow: auto !important;
	}
</style>

<style>
	.entrance-link {
		position: absolute;
		top: 2rem;
		right: 2rem;
		color: white;
		text-decoration: none;
		font-size: 0.8rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		opacity: 0.8;
		transition: opacity 0.3s ease;
		z-index: 10;
	}

	.entrance-link:hover {
		opacity: 1;
	}

	main {
		min-height: 100vh;
		width: 100%;
		background-color: magenta;
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 2rem;
	}

	.content {
		width: 100%;
		max-width: 1400px;
	}

	.columns-container {
		display: flex;
		gap: 2rem;
		align-items: flex-start;
		width: 100%;
	}

	.column {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		flex: 1;
		min-width: 0;
	}

	.sonics-link {
		color: white;
		font-size: clamp(1.5rem, 6vw, 3rem);
		text-decoration: none;
		font-weight: 700;
		letter-spacing: 4px;
		transition: opacity 0.3s ease;
		height: 4rem;
		display: flex;
		align-items: center;
	}

	.sonics-link:hover {
		opacity: 0.7;
	}

	.artist-name {
		color: white;
		font-size: clamp(1rem, 3vw, 1.5rem);
		font-weight: 400;
		letter-spacing: 8px;
		margin: 0;
		opacity: 0.9;
		white-space: nowrap;
		height: 4rem;
		display: flex;
		align-items: center;
	}

	.widget-container {
		width: 100%;
		box-shadow: 0 10px 30px rgba(0,0,0,0.2);
		opacity: 0.8;
		transition: opacity 0.3s ease;
	}

	.widget-container:hover {
		opacity: 1;
	}

	@media (max-width: 800px) {
		.columns-container {
			flex-direction: column;
			gap: 4rem;
		}
		.column {
			width: 100%;
			max-width: 80vw;
		}
	}
</style>
