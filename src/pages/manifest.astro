---
import Layout from '../layouts/Layout.astro';
---

<Layout title="cinema cabbage">
	<a href="/" class="entrance-link">entrance</a>
	<main>
		<iframe 
			class="youtube-iframe"
			src="https://www.youtube.com/embed/YdVkZHwPZHY?autoplay=0&rel=0" 
			title="YouTube video player" 
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
			allowfullscreen>
		</iframe>
	</main>
</Layout>

<style>
	.entrance-link {
		position: absolute;
		top: 2rem;
		right: 2rem;
		color: white;
		text-decoration: none;
		font-size: 0.8rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		opacity: 0.5;
		transition: opacity 0.3s ease;
		z-index: 10;
	}

	.entrance-link:hover {
		opacity: 1;
	}

	main {
		width: 100vw;
		height: 100vh;
		background-color: #000000;
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: hidden;
	}

	.youtube-iframe {
		width: 100%;
		max-width: 1200px;
		aspect-ratio: 16 / 9;
		border: none;
		box-shadow: 0 0 50px rgba(0,0,0,0.5);
	}

	@media (max-width: 1280px) {
		.youtube-iframe {
			width: 90%;
		}
	}

	@media (max-width: 480px) {
		.youtube-iframe {
			width: 100%;
		}
	}
</style>
